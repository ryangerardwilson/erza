<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>erza</title>
    <meta
      name="description"
      content="erza is a terminal-native language project for component-driven interfaces and the future erzanet."
    />
    <link rel="stylesheet" href="/assets/site.css" />
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">erza</a>
        <nav class="nav">
          <? for item in nav ?>
            <a href="<?= item.href ?>"><?= item.label ?></a>
          <? endfor ?>
        </nav>
      </header>

      <main>
        <section class="hero hero-grid-shell">
          <div class="hero-copy">
            <p class="eyebrow">terminal-native interface language</p>
            <h1>erzanet starts by making the docs site worth opening in-terminal</h1>
            <p class="lede">
              This site is no longer just a brochure. It is a capability lab
              for what an <code>erza</code> experience should feel like when
              it is opened directly from the terminal instead of through a
              browser tab stack.
            </p>
            <div class="command-list command-list-tight">
              <? for command in commands ?>
                <div class="command-card">
                  <p class="command-label"><?= command.label ?></p>
                  <pre><code><?= command.command ?></code></pre>
                </div>
              <? endfor ?>
            </div>
          </div>

          <div class="terminal-window">
            <div class="terminal-window-bar">
              <span>erza.ryangerardwilson.com</span>
              <span>79 cols</span>
            </div>
            <pre><code>erza

+-[ Component Lab ]------------------------------------------------------------+
| Component-first, boxed, keyboard-native, and remote-testable.               |
|                                                                             |
| ctrl-n/p regions   gg top   G end   j/k within   h back   l open           |
|                                                                             |
| open /components/ to inspect nesting rules and /labs/ to audit gaps.       |
+-----------------------------------------------------------------------------+</code></pre>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">thesis</p>
            <h2>Why the site needs to get more complex</h2>
          </div>
          <div class="card-grid">
            <? for pillar in pillars ?>
              <article class="card">
                <h3><?= pillar.title ?></h3>
                <p><?= pillar.body ?></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">component map</p>
            <h2>The current families in play</h2>
          </div>
          <div class="card-grid">
            <? for family in component_families ?>
              <article class="card">
                <h3><?= family.name ?></h3>
                <p><?= family.summary ?></p>
                <ul class="bullet-list">
                  <? for item in family.items ?>
                    <li><code><?= item ?></code></li>
                  <? endfor ?>
                </ul>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/components/">Open the component gallery</a></p>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">patterns</p>
            <h2>Layouts worth testing against the runtime</h2>
          </div>
          <div class="card-grid">
            <? for pattern in patterns ?>
              <article class="card">
                <h3><?= pattern.name ?></h3>
                <p><?= pattern.summary ?></p>
                <p><strong>Regions:</strong> <?= pattern.regions ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/patterns/">Open the pattern library</a></p>
        </section>

        <section class="section section-accent">
          <div class="section-heading">
            <p class="eyebrow">labs</p>
            <h2>Capability matrix for the current stack</h2>
          </div>
          <div class="matrix-grid">
            <? for item in capability_matrix ?>
              <article class="step-card">
                <h3><?= item.feature ?></h3>
                <p><strong>Runtime:</strong> <?= item.runtime ?></p>
                <p><strong>Docs HTML:</strong> <?= item.docs ?></p>
                <p><strong>Remote Viewer:</strong> <?= item.remote ?></p>
                <p><strong>Erzanet:</strong> <?= item.erzanet ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/labs/">Open the labs page</a></p>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">examples</p>
            <h2>Runnable local surfaces</h2>
          </div>
          <div class="card-grid">
            <? for example in examples ?>
              <article class="card">
                <h3><?= example.name ?></h3>
                <p><?= example.summary ?></p>
                <p><code><?= example.path ?></code></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">next hop</p>
            <h2>Remote apps over HTTPS</h2>
          </div>
          <div class="flow-grid">
            <? for item in protocol_steps ?>
              <article class="step-card">
                <p class="step-number"><?= item.step ?></p>
                <h3><?= item.title ?></h3>
                <p><?= item.body ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link">
            <a href="/protocol/">Read the remote-mode notes</a>
          </p>
        </section>
      </main>

      <footer class="footer">
        <div>
          <p>Docs URL: <a href="<?= site.url ?>"><?= site.domain ?></a></p>
          <p>Source: <a href="<?= site.repo_url ?>"><?= site.repo_url ?></a></p>
        </div>
        <p>Built <?= site.build_stamp ?></p>
      </footer>
    </div>
  </body>
</html>
