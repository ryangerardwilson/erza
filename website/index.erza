<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>erza</title>
    <meta
      name="description"
      content="erza is a terminal-native language project for component-driven interfaces and the future erzanet."
    />
    <link rel="stylesheet" href="/assets/site.css" />
    <script src="/assets/site.js" defer></script>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">erza</a>
        <nav class="nav">
          <? for item in nav ?>
            <a href="<?= item.href ?>"><?= item.label ?></a>
          <? endfor ?>
        </nav>
      </header>

      <main>
        <section class="hero hero-story">
          <p class="eyebrow">terminal-first internet</p>
          <div class="story-stack">
            <p class="story-prefix">What if</p>
            <h1 class="story-rotator">
              <span
                class="typewriter-target"
                data-phrases='<?= story_phrases_json ?>'
              >the internet did not need a web browser or Android/iOS gatekeepers?</span>
            </h1>
          </div>
          <p class="lede story-lede">
            <code>erza</code> is the wager that websites, product surfaces,
            and documentation can be designed CLI and TUI first, then opened
            over HTTPS without leaving the terminal.
          </p>
        </section>

        <section class="section section-first">
          <div class="page-grid demo-grid">
            <div class="demo-column">
              <div class="section-heading section-heading-compact">
                <p class="eyebrow">input</p>
                <h2>Landing page in <code>.erza</code></h2>
              </div>
              <div class="hero-code">
                <pre class="code-block"><code><?= landing_markup ?></code></pre>
              </div>
            </div>

            <div class="demo-column">
              <div class="section-heading section-heading-compact">
                <p class="eyebrow">output</p>
                <h2>Latest terminal capture</h2>
              </div>
              <div class="command-card command-card-feature">
                <p class="command-label">run from repo root</p>
                <pre><code><?= landing_command ?></code></pre>
              </div>
              <div class="terminal-window video-placeholder">
                <div class="terminal-window-bar">
                  <span>captured hero demo</span>
                  <span>examples/landing</span>
                </div>
                <video
                  class="hero-video"
                  src="<?= landing_video ?>"
                  autoplay
                  muted
                  loop
                  playsinline
                  controls
                ></video>
              </div>
              <p class="protocol-link">
                The current demo uses the latest local recording of the centered
                79-column runtime.
              </p>
            </div>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">thesis</p>
            <h2>Why this site exists</h2>
          </div>
          <div class="card-grid">
            <? for pillar in pillars ?>
              <article class="card">
                <h3><?= pillar.title ?></h3>
                <p><?= pillar.body ?></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">component map</p>
            <h2>What exists today</h2>
          </div>
          <div class="card-grid">
            <? for family in component_families ?>
              <article class="card">
                <h3><?= family.name ?></h3>
                <p><?= family.summary ?></p>
                <ul class="bullet-list">
                  <? for item in family.items ?>
                    <li><code><?= item ?></code></li>
                  <? endfor ?>
                </ul>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/components/">Open the component gallery</a></p>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">patterns</p>
            <h2>Reference surfaces</h2>
          </div>
          <div class="card-grid">
            <? for pattern in patterns ?>
              <article class="card">
                <h3><?= pattern.name ?></h3>
                <p><?= pattern.summary ?></p>
                <p><strong>Regions:</strong> <?= pattern.regions ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/patterns/">Open the pattern library</a></p>
        </section>

        <section class="section section-accent">
          <div class="section-heading">
            <p class="eyebrow">labs</p>
            <h2>What works where</h2>
          </div>
          <div class="matrix-grid">
            <? for item in capability_matrix ?>
              <article class="step-card">
                <h3><?= item.feature ?></h3>
                <p><strong>Runtime:</strong> <?= item.runtime ?></p>
                <p><strong>Docs HTML:</strong> <?= item.docs ?></p>
                <p><strong>Remote Viewer:</strong> <?= item.remote ?></p>
                <p><strong>Erzanet:</strong> <?= item.erzanet ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link"><a href="/labs/">Open the labs page</a></p>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">examples</p>
            <h2>Runnable local surfaces</h2>
          </div>
          <div class="card-grid">
            <? for example in examples ?>
              <article class="card">
                <h3><?= example.name ?></h3>
                <p><?= example.summary ?></p>
                <p><code><?= example.path ?></code></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">commands</p>
            <h2>Open the current surfaces</h2>
          </div>
          <div class="command-list command-list-tight">
            <? for command in commands ?>
              <div class="command-card">
                <p class="command-label"><?= command.label ?></p>
                <pre><code><?= command.command ?></code></pre>
              </div>
            <? endfor ?>
          </div>
        </section>

        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">next hop</p>
            <h2>Remote mode over HTTPS</h2>
          </div>
          <div class="flow-grid">
            <? for item in protocol_steps ?>
              <article class="step-card">
                <p class="step-number"><?= item.step ?></p>
                <h3><?= item.title ?></h3>
                <p><?= item.body ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link">
            <a href="/protocol/">Read the remote-mode notes</a>
          </p>
        </section>
      </main>

      <footer class="footer">
        <div>
          <p>Docs URL: <a href="<?= site.url ?>"><?= site.domain ?></a></p>
          <p>Source: <a href="<?= site.repo_url ?>"><?= site.repo_url ?></a></p>
        </div>
        <p>Built <?= site.build_stamp ?></p>
      </footer>
    </div>
  </body>
</html>
