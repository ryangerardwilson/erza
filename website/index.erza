<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>erza</title>
    <meta
      name="description"
      content="erza is a terminal-first language project for building TUIs and exploring network-addressed terminal apps."
    />
    <link rel="stylesheet" href="/assets/site.css" />
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">erza</a>
        <nav class="nav">
          <? for item in nav ?>
            <a href="<?= item.href ?>"><?= item.label ?></a>
          <? endfor ?>
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="eyebrow">terminal ui language</p>
          <h1>Section-first terminal components</h1>
          <p class="lede">
            This documentation site is authored in <code>.erza</code> and
            compiled into static HTML for GitHub Pages. It doubles as a small
            testbed for the idea that erza screens should be built from named
            sections, sparse actions, and predictable keyboard movement.
          </p>

          <div class="hero-grid">
            <div class="panel">
              <h2>Screen shape</h2>
              <p>
                A screen is a stack of components. Each section should do one
                job instead of scattering headings, buttons, and loose focus
                targets across the page.
              </p>
            </div>
            <div class="panel">
              <h2>Navigation contract</h2>
              <p>
                <code>Ctrl+N</code> and <code>Ctrl+P</code> switch sections.
                <code>gg</code> jumps to the first section and <code>G</code>
                jumps to the last. <code>j</code> and <code>k</code> move
                within the active section. <code>h</code> goes back.
                <code>l</code> opens the selected link or action.
              </p>
            </div>
          </div>
        </section>

        <section id="model" class="section">
          <div class="section-heading">
            <p class="eyebrow">model</p>
            <h2>Why the language is being reshaped</h2>
          </div>
          <div class="card-grid">
            <? for pillar in pillars ?>
              <article class="card">
                <h3><?= pillar.title ?></h3>
                <p><?= pillar.body ?></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section id="components" class="section">
          <div class="section-heading">
            <p class="eyebrow">components</p>
            <h2>The new public vocabulary</h2>
          </div>
          <div class="card-grid">
            <? for component in components ?>
              <article class="card">
                <h3><code><?= component.tag ?></code></h3>
                <p><?= component.summary ?></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section id="run" class="section">
          <div class="section-heading">
            <p class="eyebrow">run</p>
            <h2>Try the current prototype</h2>
          </div>
          <div class="command-list">
            <? for command in commands ?>
              <div class="command-card">
                <p class="command-label"><?= command.label ?></p>
                <pre><code><?= command.command ?></code></pre>
              </div>
            <? endfor ?>
          </div>
        </section>

        <section id="examples" class="section">
          <div class="section-heading">
            <p class="eyebrow">examples</p>
            <h2>What is already running</h2>
          </div>
          <div class="card-grid">
            <? for example in examples ?>
              <article class="card">
                <h3><?= example.name ?></h3>
                <p><?= example.summary ?></p>
                <p><code><?= example.path ?></code></p>
              </article>
            <? endfor ?>
          </div>
        </section>

        <section class="section section-accent">
          <div class="section-heading">
            <p class="eyebrow">next hop</p>
            <h2>Remote apps over HTTPS</h2>
          </div>
          <div class="flow-grid">
            <? for item in protocol_steps ?>
              <article class="step-card">
                <p class="step-number"><?= item.step ?></p>
                <h3><?= item.title ?></h3>
                <p><?= item.body ?></p>
              </article>
            <? endfor ?>
          </div>
          <p class="protocol-link">
            <a href="/protocol/">Read the remote-mode notes</a>
          </p>
        </section>
      </main>

      <footer class="footer">
        <div>
          <p>Docs URL: <a href="<?= site.url ?>"><?= site.domain ?></a></p>
          <p>Source: <a href="<?= site.repo_url ?>"><?= site.repo_url ?></a></p>
        </div>
        <p>Built <?= site.build_stamp ?></p>
      </footer>
    </div>
  </body>
</html>
